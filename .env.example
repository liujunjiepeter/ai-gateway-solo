# 统一网关 Token（Claude-3p 里填这个）
PROXY_TOKEN=sk-my-unified-gateway-token

# 后端 API Key（真实厂商 Key，proxy 内部鉴权用，Claude-3p 看不到）
DEEPSEEK_API_KEY=sk-your-deepseek-key
XIAOMI_API_KEY=tp-your-xiaomi-key

# 💡 模型名映射（在 proxy.py 中配置，这里仅做说明）
# 客户端发 claude-3-5-sonnet-20241022 → 自动映射到 deepseek-v4-pro
# 客户端发 claude-3-5-haiku-20241022 → 自动映射到 mimo-v2.5
# 如需修改映射，请编辑 proxy.py 中的 MODEL_MAPPING 字典

# 端口（可选，默认 9999）
PORT=9999
